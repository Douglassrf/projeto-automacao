# Perfil: production (Missão 41 — Configuração Centralizada)
#
# Carregado quando APP_ENV=production|prod|producao|produção.
#
# validate_or_raise() é estrito neste perfil: get_settings() levanta
# ConfigValidationError (e a aplicação não inicia) se qualquer um destes
# estiver errado:
#   - AUTH_REQUIRED=false
#   - JWT_SECRET_KEY ainda for o placeholder de desenvolvimento, ou tiver
#     menos de 32 caracteres
#   - META_ALLOW_PRODUCTION_REAL=true sem META_REQUIRE_MANUAL_CONFIRMATION=true
#   - DEFAULT_ADMIN_PASSWORD ausente
#
# Os valores abaixo são exemplos de FORMATO, não segredos reais. Gere um
# segredo de verdade antes de usar (ex.: `openssl rand -hex 32`).

APP_ENV=production
AUTH_REQUIRED=true
JWT_SECRET_KEY=gere-um-segredo-real-com-32-ou-mais-caracteres-aqui
DEFAULT_ADMIN_PASSWORD=defina-uma-senha-forte-de-producao-aqui
META_ENV=production
META_DRY_RUN=false
META_ALLOW_PRODUCTION_REAL=false
META_REQUIRE_MANUAL_CONFIRMATION=true
APP_LOG_LEVEL=INFO
