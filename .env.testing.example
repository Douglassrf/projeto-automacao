# Perfil: testing (Missão 41 — Configuração Centralizada)
#
# Carregado quando APP_ENV=testing|test|teste.
# validate_or_raise() é estrito neste perfil: bloqueia (ConfigValidationError)
# se meta_env="production" ou meta_allow_production_real=true, para impedir
# que a suíte de testes acidentalmente chame a Meta API real.

APP_ENV=testing
AUTH_REQUIRED=false
META_ENV=sandbox
META_DRY_RUN=true
META_ALLOW_PRODUCTION_REAL=false
DEFAULT_ADMIN_PASSWORD=test-admin-password
APP_LOG_LEVEL=WARNING
