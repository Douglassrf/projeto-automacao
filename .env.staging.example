# Perfil: staging / homologação (Missão 41 — Configuração Centralizada)
#
# Carregado quando APP_ENV=staging|homolog|homologacao|homologação|stage.
# Mesma rigidez de segredo recomendada para produção, mas com a Meta API
# ainda em modo sandbox/dry-run — homologação não deve gastar orçamento real.

APP_ENV=staging
AUTH_REQUIRED=true
JWT_SECRET_KEY=troque-este-valor-por-um-segredo-real-de-32-chars-ou-mais
META_ENV=sandbox
META_DRY_RUN=true
META_ALLOW_PRODUCTION_REAL=false
DEFAULT_ADMIN_PASSWORD=troque-esta-senha-de-homologacao
APP_LOG_LEVEL=INFO
