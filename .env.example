# Projeto Automação — variáveis de ambiente de exemplo
# Nunca colocar chaves reais neste arquivo.

APP_NAME=AdIntelligence Pro
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=sqlite:///./adintelligence.db

AUTH_REQUIRED=false
JWT_SECRET_KEY=change-me-local-dev-only
DEFAULT_ADMIN_NAME=Douglas
DEFAULT_ADMIN_EMAIL=admin@example.com
# OBRIGATORIO: sem valor aqui, a aplicacao falha ao iniciar (RuntimeError).
# Nao existe mais senha padrao no codigo-fonte por seguranca.
DEFAULT_ADMIN_PASSWORD=troque-esta-senha-em-producao

META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

META_PAGE_ID=
META_INSTAGRAM_ACTOR_ID=
META_PIXEL_ID=
META_ENV=sandbox
META_DRY_RUN=true
META_ALLOW_ACTIVE_LAUNCH=false
META_AUTOPUBLISH=false
META_ALLOW_PRODUCTION_REAL=false

OPENAI_API_KEY=

OLLAMA_MODEL=llama3.1

ELEVENLABS_API_KEY=


HUGGINGFACE_TOKEN=


GITHUB_TOKEN=

VERCEL_TOKEN=

NETLIFY_TOKEN=


KIT_OUTPUT_DIR=./data/campaign_kits
SITE_OUTPUT_DIR=./data/generated_sites
ORCHESTRATION_OUTPUT_DIR=./data/orchestration_runs

OBSERVABILITY_ENABLED=true
LOG_LEVEL=INFO           
