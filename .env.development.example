# Perfil: development (Missão 41 — Configuração Centralizada)
#
# Carregado quando APP_ENV não está definido, ou APP_ENV=development|dev.
# Ordem de carga: ".env.development" primeiro, depois ".env" (que pode
# sobrescrever). Nenhuma variável aqui é obrigatória — são apenas os
# valores recomendados para desenvolvimento local.
#
# Para usar: copie para ".env.development" (ou simplesmente use o ".env.example"
# já existente na raiz, que cobre o mesmo cenário e continua funcionando sem
# nenhuma mudança).

APP_ENV=development
AUTH_REQUIRED=false
META_ENV=sandbox
META_DRY_RUN=true
META_ALLOW_PRODUCTION_REAL=false
OBSERVABILITY_ENABLED=true
APP_LOG_LEVEL=DEBUG
